class Solution:
    def stringIndices(self, wordsContainer: List[str], wordsQuery: List[str]) -> List[int]:
        
        trie = [[-1, {}]]  
        # each node = [best_index, children_dictionary]

        def is_better(i, j):
            if j == -1:
                return i

            if len(wordsContainer[i]) < len(wordsContainer[j]):
                return i

            if len(wordsContainer[i]) == len(wordsContainer[j]) and i < j:
                return i

            return j

        # Find default answer: shortest word, earliest index
        default_index = 0
        for i in range(1, len(wordsContainer)):
            default_index = is_better(i, default_index)

        trie[0][0] = default_index

        # Build trie using reversed words
        for i, word in enumerate(wordsContainer):
            node = 0

            trie[node][0] = is_better(i, trie[node][0])

            for ch in reversed(word):
                children = trie[node][1]

                if ch not in children:
                    children[ch] = len(trie)
                    trie.append([-1, {}])

                node = children[ch]

                trie[node][0] = is_better(i, trie[node][0])

        ans = []

        # Search each query
        for query in wordsQuery:
            node = 0
            best_index = trie[node][0]

            for ch in reversed(query):
                children = trie[node][1]

                if ch not in children:
                    break

                node = children[ch]
                best_index = trie[node][0]

            ans.append(best_index)

        return ans
