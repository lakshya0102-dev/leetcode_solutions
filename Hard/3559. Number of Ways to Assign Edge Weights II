class Solution:
    def assignEdgeWeights(self, edges: List[List[int]], queries: List[List[int]]) -> List[int]:
        MOD = 10**9 + 7
        n = len(edges) + 1

        graph = defaultdict(list)

        for u, v in edges:
            graph[u].append(v)
            graph[v].append(u)

        LOG = (n + 1).bit_length()

        parent = [[0] * LOG for _ in range(n + 1)]
        depth = [0] * (n + 1)

        # BFS from root node 1
        queue = deque([1])
        visited = [False] * (n + 1)
        visited[1] = True

        while queue:
            node = queue.popleft()

            for nei in graph[node]:
                if not visited[nei]:
                    visited[nei] = True
                    depth[nei] = depth[node] + 1
                    parent[nei][0] = node
                    queue.append(nei)

        # Build binary lifting table
        for j in range(1, LOG):
            for node in range(1, n + 1):
                parent[node][j] = parent[parent[node][j - 1]][j - 1]

        def lca(u, v):
            if depth[u] < depth[v]:
                u, v = v, u

            # Lift u to the same depth as v
            diff = depth[u] - depth[v]

            for j in range(LOG):
                if diff & (1 << j):
                    u = parent[u][j]

            if u == v:
                return u

            # Lift both until their parents become same
            for j in range(LOG - 1, -1, -1):
                if parent[u][j] != parent[v][j]:
                    u = parent[u][j]
                    v = parent[v][j]

            return parent[u][0]

        answer = []

        for u, v in queries:
            ancestor = lca(u, v)

            dist = depth[u] + depth[v] - 2 * depth[ancestor]

            if dist == 0:
                answer.append(0)
            else:
                answer.append(pow(2, dist - 1, MOD))

        return answer
