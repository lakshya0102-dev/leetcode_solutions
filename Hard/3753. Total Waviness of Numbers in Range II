class Solution:
    def totalWaviness(self, num1: int, num2: int) -> int:
        
        def count_upto(n: int) -> int:
            if n <= 0:
                return 0

            digits = list(map(int, str(n)))
            m = len(digits)

            @lru_cache(None)
            def dp(pos, tight, length, prev2, prev1):
                if pos == m:
                    return (1, 0)  
                    # number count, total waviness sum

                limit = digits[pos] if tight else 9

                total_numbers = 0
                total_wavy = 0

                for d in range(limit + 1):
                    new_tight = tight and (d == limit)

                    if length == 0 and d == 0:
                        cnt, wav = dp(pos + 1, new_tight, 0, -1, -1)
                        total_numbers += cnt
                        total_wavy += wav

                    elif length == 0:
                        cnt, wav = dp(pos + 1, new_tight, 1, -1, d)
                        total_numbers += cnt
                        total_wavy += wav

                    elif length == 1:
                        cnt, wav = dp(pos + 1, new_tight, 2, prev1, d)
                        total_numbers += cnt
                        total_wavy += wav

                    else:
                        add = 0

                        if prev1 > prev2 and prev1 > d:
                            add = 1
                        elif prev1 < prev2 and prev1 < d:
                            add = 1

                        cnt, wav = dp(pos + 1, new_tight, 2, prev1, d)

                        total_numbers += cnt
                        total_wavy += wav + add * cnt

                return (total_numbers, total_wavy)

            return dp(0, True, 0, -1, -1)[1]

        return count_upto(num2) - count_upto(num1 - 1)
