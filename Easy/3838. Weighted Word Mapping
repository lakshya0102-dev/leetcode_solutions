class Solution:
    def mapWordWeights(self, words: List[str], weights: List[int]) -> str:
        answer = ""

        for word in words:
            total = 0

            for ch in word:
                index = ord(ch) - ord('a')
                total += weights[index]

            mod_value = total % 26
            mapped_char = chr(ord('z') - mod_value)

            answer += mapped_char

        return answer
