class Solution:
    def numberOfSpecialChars(self, word: str) -> int:
        count = 0
        for ch in 'abcdefghijklmnopqrstuvwxyz':
            lower = ch
            upper = ch.upper()
            if lower in word and upper in word:
                last_lower_index = word.rfind(lower)
                first_upper_index = word.find(upper)
                if last_lower_index < first_upper_index:
                    count += 1

        return count